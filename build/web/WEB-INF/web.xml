<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.LoginServlet</servlet-class>
        <init-param>
            <param-name>jdbcClassName</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
        <init-param>
            <param-name>dbUserName</param-name>
            <param-value>app</param-value>
            <!--<param-value>root</param-value>-->
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>jdbcDriverURL</param-name>
            <param-value>jdbc:derby</param-value>
        </init-param>
        <init-param>
            <param-name>dbHostName</param-name>
            <param-value>localhost</param-value>
        </init-param>
        <init-param>
            <param-name>dbPort</param-name>
            <param-value>1527</param-value>
        </init-param>
        <init-param>
            <param-name>databaseName</param-name>
            <param-value>LoginDB</param-value>
        </init-param>
    </servlet>
    <servlet>
        <servlet-name>SeedingServlet</servlet-name>
        <servlet-class>controller.SeedingServlet</servlet-class>
        <init-param>
            <param-name>jdbcClassName</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
        <init-param>
            <param-name>dbUserName</param-name>
            <param-value>app</param-value>
            <!--<param-value>root</param-value>-->
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>jdbcDriverURL</param-name>
            <param-value>jdbc:derby</param-value>
        </init-param>
        <init-param>
            <param-name>dbHostName</param-name>
            <param-value>localhost</param-value>
        </init-param>
        <init-param>
            <param-name>dbPort</param-name>
            <param-value>1527</param-value>
        </init-param>
        <init-param>
            <param-name>databaseName</param-name>
            <param-value>LoginDB</param-value>
        </init-param>
    </servlet>
    <servlet>
        <servlet-name>AuthenticationFilterServlet</servlet-name>
        <servlet-class>controller.AuthenticationFilter</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ExamServlet</servlet-name>
        <servlet-class>controller.ExamServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>controller.ReportServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ConnectionTestServlet</servlet-name>
        <servlet-class>controller.ConnectionTestServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>controller.HomeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CaptchaServlet</servlet-name>
        <servlet-class>controller.CaptchaServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DirectoryServlet</servlet-name>
        <servlet-class>controller.DirectoryServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TableInitializationServlet</servlet-name>
        <servlet-class>controller.TableInitializationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SeedingServlet</servlet-name>
        <url-pattern>/seed</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AuthenticationFilterServlet</servlet-name>
        <url-pattern>/AuthenticationFilterServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ExamServlet</servlet-name>
        <url-pattern>/takeExam</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/generateReport</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CaptchaServlet</servlet-name>
        <url-pattern>/captcha</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ConnectionTestServlet</servlet-name>
        <url-pattern>/test</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DirectoryServlet</servlet-name>
        <url-pattern>/directory</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TableInitializationServlet</servlet-name>
        <url-pattern>/create</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <context-param>
        <param-name>secretKey</param-name>
        <param-value>caesarsaladisyum</param-value>
    </context-param>
    <context-param>
        <param-name>cipherAlgorithm</param-name>
        <param-value>AES</param-value>
    </context-param>
    <context-param>
        <param-name>cipherMode</param-name>
        <param-value>ECB</param-value>
    </context-param>
    <context-param>
        <param-name>cipherPadding</param-name>
        <param-value>PKCS5Padding</param-value>
    </context-param>
    <context-param>
        <param-name>DerbyURL</param-name>
        <param-value>jdbc:derby://localhost:1527/UserDB</param-value>
    </context-param>
    <context-param>
        <param-name>DerbyUser</param-name>
        <param-value>app</param-value>
    </context-param>
    <context-param>
        <param-name>DerbyPass</param-name>
        <param-value>app</param-value>
    </context-param>
    <context-param>
        <param-name>ExamDBURL</param-name>
        <param-value>jdbc:postgresql://localhost:5432/ExamDB</param-value>
    </context-param>
    <context-param>
        <param-name>ExamDBUser</param-name>
        <param-value>postgres</param-value>
    </context-param>
    <context-param>
        <param-name>ExamDBPass</param-name>
        <param-value>1</param-value>
    </context-param>
    <context-param>
        <param-name>CertDBURL</param-name>
        <param-value>jdbc:mysql://localhost:3306/CertDB</param-value>
    </context-param>
    <context-param>
        <param-name>CertDBUser</param-name>
        <param-value>root</param-value>
    </context-param>
    <context-param>
        <param-name>CertDBPass</param-name>
        <param-value>root</param-value>
    </context-param>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsps/errorpages/error_404.jsp</location>
    </error-page>
    <error-page>
        <error-code>405</error-code>
        <location>/WEB-INF/jsps/errorpages/error_405.jsp</location>
    </error-page>
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>controller.AuthenticationFilter</filter-class>
        <!-- Define pages or paths that the security guard should ignore -->
        <init-param>
            <param-name>excludedPaths</param-name>
            <param-value>/index.jsp,/css/main.css</param-value>
        </init-param>
    </filter>
    <!-- Derby Reference -->
    <resource-ref>
        <description>Derby Database for User Authentication Data</description>
        <res-ref-name>jdbc/UserDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>
    <!-- MySQL Reference -->
    <resource-ref>
        <description>MySQL Database for Student Certifications</description>
        <res-ref-name>jdbc/CertDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>
    <!-- PostgreSQL Reference -->
    <resource-ref>
        <description>PostgreSQL Database for the Exam Bank</description>
        <res-ref-name>jdbc/ExamDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>
</web-app>
